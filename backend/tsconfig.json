  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2020",
    "types": ["node"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "declaration": true
  }
}